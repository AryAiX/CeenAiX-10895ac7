# ─────────────────────────────────────────────────────────────────────────────
# CeenAiX — Azure UAE self-hosted Supabase stack environment template.
#
# This file configures the OFFICIAL supabase/docker compose stack (Postgres,
# Kong, GoTrue/Auth, PostgREST, Storage, Realtime, Studio, Edge Runtime) running
# on a single Azure VM in Azure UAE North. Copy it into the supabase/docker
# checkout as `.env` and fill in REAL, GENERATED secrets.
#
#   cp infra/azure-uae/.env.example /opt/supabase/docker/.env   # then edit
#
# NEVER commit a filled-in copy. NEVER reuse the placeholder values below in any
# environment — every secret here must be freshly generated (see the runbook:
# docs/runbooks/azure-uae-environment.md, "Generate secrets").
#
# This is a SUPERSET tailored to CeenAiX. Keep it in sync with the upstream
# `supabase/docker/.env.example` when you bump the stack version.
# ─────────────────────────────────────────────────────────────────────────────

############
# Secrets — GENERATE THESE. Do not ship placeholders to a live host.
############

# Postgres superuser password (also used by internal services).
POSTGRES_PASSWORD=__CHANGE_ME_db_password__

# JWT signing secret (min 32 chars). ANON_KEY and SERVICE_ROLE_KEY below MUST be
# JWTs signed with THIS secret. Regenerate all three together.
JWT_SECRET=__CHANGE_ME_min_32_char_jwt_secret__

# Anon (publishable) key — JWT signed with JWT_SECRET, role "anon".
# This is what the web/mobile apps use as VITE_SUPABASE_ANON_KEY / EXPO_PUBLIC_*.
ANON_KEY=__CHANGE_ME_anon_jwt__

# Service role (secret) key — JWT signed with JWT_SECRET, role "service_role".
# Server-side / Edge Functions only. NEVER expose to the browser or mobile app.
SERVICE_ROLE_KEY=__CHANGE_ME_service_role_jwt__

# Newer upstream Supabase docker images also expect publishable/secret key
# aliases. Keep these unique so Kong does not see duplicate key-auth credentials.
SUPABASE_PUBLISHABLE_KEY=__CHANGE_ME_publishable_key__
SUPABASE_SECRET_KEY=__CHANGE_ME_secret_key__

# Supabase Studio dashboard basic-auth credentials (Kong protects Studio).
DASHBOARD_USERNAME=ceenaix-admin
DASHBOARD_PASSWORD=__CHANGE_ME_dashboard_password__

# Secret key base / encryption keys used by GoTrue + Realtime + Vault.
SECRET_KEY_BASE=__CHANGE_ME_64_char_hex__
VAULT_ENC_KEY=__CHANGE_ME_32_char_key__
PG_META_CRYPTO_KEY=__CHANGE_ME_32_char_key__

############
# Database — internal (single-VM) defaults. Point at Azure Database for
# PostgreSQL Flexible Server here when graduating to Option 2 (no app rewrite).
############
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
# For Option 2 (managed Postgres): set POSTGRES_HOST to the Flexible Server FQDN
# (e.g. ceenaix-uae.postgres.database.azure.com) and stop the `db` container.

############
# API / gateway — public endpoints. Must match the app's VITE_SUPABASE_URL.
############
# Public base URL clients hit (Caddy terminates TLS and proxies to Kong:8000).
API_EXTERNAL_URL=https://api.uae.ceenaix.com
SUPABASE_PUBLIC_URL=https://api.uae.ceenaix.com

# Kong listens internally; Caddy is the only thing exposed to the internet.
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
PGRST_DB_SCHEMAS=public,storage,graphql_public

############
# Auth (GoTrue)
############
# Where the app redirects after auth actions. Web app origin.
SITE_URL=https://uae.ceenaix.com
# Comma-separated additional allowed redirect origins (web + mobile deep links).
ADDITIONAL_REDIRECT_URLS=https://uae.ceenaix.com,ceenaix://auth-callback
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false

############
# Email / SMTP — reuse the same Resend SMTP used by Cloud (see prod runbook).
############
SMTP_ADMIN_EMAIL=no-reply@mail.ceenaix.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=__CHANGE_ME_resend_api_key__
SMTP_SENDER_NAME=CeenAiX
MAILER_URLPATHS_CONFIRMATION=/auth/confirm
MAILER_URLPATHS_INVITE=/auth/confirm
MAILER_URLPATHS_RECOVERY=/auth/reset-password
MAILER_URLPATHS_EMAIL_CHANGE=/auth/confirm

############
# Studio / Meta
############
STUDIO_DEFAULT_ORGANIZATION=AryAiX
STUDIO_DEFAULT_PROJECT=ceenaix-uae
# OpenAI key is OPTIONAL for Studio SQL assistant only. The CeenAiX Edge
# Functions read their own OPENAI_API_KEY as a function secret (see below).
OPENAI_API_KEY=

############
# Storage
############
# Local file backend on the VM data disk by default. Swap to S3-compatible
# (Azure Blob via a gateway) later if needed.
STORAGE_BACKEND=file
FILE_SIZE_LIMIT=52428800
STORAGE_TENANT_ID=stub
GLOBAL_S3_BUCKET=stub
REGION=local
S3_PROTOCOL_ACCESS_KEY_ID=__CHANGE_ME_s3_protocol_access_key_id__
S3_PROTOCOL_ACCESS_KEY_SECRET=__CHANGE_ME_s3_protocol_access_key_secret__
IMGPROXY_AUTO_WEBP=true

############
# Edge Functions (Deno runtime)
############
# Secrets injected into ALL functions. CeenAiX functions (consultation-scribe,
# ai-chat, ai-document-analyze) need OPENAI_API_KEY. The runtime already gets
# SUPABASE_URL / ANON / SERVICE_ROLE from the stack.
FUNCTIONS_VERIFY_JWT=false

############
# Connection pooler (Supavisor)
############
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=ceenaix-uae
POOLER_DEFAULT_POOL_SIZE=20
POOLER_DB_POOL_SIZE=5

############
# Realtime — present in the stack but UNUSED by CeenAiX today (no subscriptions).
# Left enabled (cheap) so the stack matches upstream; can be disabled to save RAM.
############

############
# Logging (Logflare/analytics) — optional. Disable on a small single VM if RAM
# is tight; the app does not depend on it.
############
