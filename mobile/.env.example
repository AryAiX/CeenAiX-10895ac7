# CeenAiX Mobile environment template.
#
# Copy to `.env` (git-ignored) and fill in the values for the Supabase
# project you are targeting. These mirror the web app's VITE_SUPABASE_*
# variables; Expo exposes any var prefixed with EXPO_PUBLIC_ to the client.
#
# Where to find the values:
#   Supabase Dashboard -> Settings -> API
#   - EXPO_PUBLIC_SUPABASE_URL      = "Project URL"
#   - EXPO_PUBLIC_SUPABASE_ANON_KEY = "anon" / "publishable" key
#     (NEVER the service_role / secret key — this runs on-device).

EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>

# Optional: override the Edge Functions base URL. Mobile does not call Edge
# Functions today, so leave this unset (functions resolve to
# `${EXPO_PUBLIC_SUPABASE_URL}/functions/v1` by convention). Set it only when
# targeting a self-host that serves functions on a separate host/domain — e.g.
# the Azure UAE self-host (see docs/runbooks/azure-uae-environment.md).
# EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL=https://api.uae.ceenaix.com/functions/v1

# Reference: known projects (same backend as the web app)
#   dev   ref = lgfaucsfiyxvmsghnpey
#   prod  ref = ziykaxyadcdmyakzvjff
#   UAE self-host (Azure UAE North) — self-generated keys; see runbook above
