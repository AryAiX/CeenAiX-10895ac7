# CeenAiX environment template.
#
# Copy to one of:
#   .env.local                — used by Vite dev server (`npm run dev`)
#   .env.production.local     — used by `npm run build` when targeting prod
# and fill in the values for the matching Supabase project.
#
# Real .env.* files are git-ignored; only .env.example is committed.
#
# Where to find the values:
#   Supabase Dashboard → Settings → API → Project URL + Project API keys.
#   - VITE_SUPABASE_URL = "Project URL"
#   - VITE_SUPABASE_ANON_KEY = "anon" / "publishable" key (NEVER the service_role / secret key).

# ─── Required at runtime ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-or-publishable-key>

# ─── Optional / feature flags ─────────────────────────────────────────────
# Disable the preview PIN gate when going live publicly. Default = enabled.
# VITE_PREVIEW_PIN_GATE=false

# Edge Functions base URL. Leave UNSET on Supabase Cloud or any self-host that
# serves functions behind the same gateway — the app defaults to
# `${VITE_SUPABASE_URL}/functions/v1`. Only set this when the Deno edge runtime
# is exposed on a different host/domain (see docs/runbooks/azure-uae-environment.md).
# VITE_SUPABASE_FUNCTIONS_URL=https://api.uae.ceenaix.com/functions/v1


# ─── Reference: known projects ────────────────────────────────────────────
# dev   (development)   ref = lgfaucsfiyxvmsghnpey    region = us-west-2 (Oregon)
# prod  (production)    ref = ziykaxyadcdmyakzvjff   region = us-west-2 (Oregon)
#
# Vercel env wiring (see docs/runbooks/production-environment.md):
#   - Vercel project → Settings → Environment Variables.
#   - "Production" env: prod ref values.
#   - "Preview" env: dev ref values (so PR previews still work without leaking prod).
#   - "Development" env: dev ref values.
